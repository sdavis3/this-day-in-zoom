# =============================================================================
# This Day in Zoom — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to version control.
# =============================================================================

# --- Zoom Server-to-Server OAuth ---
# Create an app at https://marketplace.zoom.us/ → Develop → Build App
# Choose "Server-to-Server OAuth" app type
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# --- OpenAI (for GPT Image 1 + optional event selection) ---
OPENAI_API_KEY=

# --- Anthropic (optional, for Claude-based event selection) ---
ANTHROPIC_API_KEY=

# --- Black Forest Labs (optional, for FLUX image generation) ---
BFL_API_KEY=
